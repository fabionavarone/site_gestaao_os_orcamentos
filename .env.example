# Copy to .env and replace all values before starting a non-development environment.
APP_ENV=development
APP_SECRET_KEY=replace-with-a-32-byte-random-secret
DATABASE_URL=postgresql+psycopg://provisao:change-me@postgres:5432/provisao
POSTGRES_PASSWORD=change-me
REDIS_URL=redis://redis:6379/0
FRONTEND_ORIGINS=http://localhost,http://127.0.0.1
PUBLIC_BASE_URL=http://localhost
BOOTSTRAP_ADMIN_EMAIL=admin@example.invalid
BOOTSTRAP_ADMIN_PASSWORD=
TELEGRAM_ENABLED=false
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_TOKEN_ENCRYPTION_KEY=
TELEGRAM_TOKEN_ENCRYPTION_PREVIOUS_KEYS=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_FILE_BASE_URL=https://api.telegram.org/file
TELEGRAM_WEBHOOK_MAX_BYTES=1048576
STORAGE_ROOT=/var/lib/provisao/uploads
MAX_IMAGE_BYTES=10485760
MAX_AUDIO_BYTES=26214400
MAX_DOCUMENT_BYTES=26214400
MAX_VIDEO_BYTES=52428800
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_LOCK_SECONDS=60
LOCAL_LLM_ENABLED=false
LOCAL_LLM_TEXT_MODEL=
LOCAL_LLM_VISION_MODEL=
LOCAL_STT_MODEL=
LOCAL_TTS_VOICE=
LOCAL_EMBEDDING_MODEL=
MAX_UPLOAD_BYTES=26214400
