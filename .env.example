# Copy to .env and replace all values before starting a non-development environment.
APP_ENV=development
APP_SECRET_KEY=replace-with-a-32-byte-random-secret
DATABASE_URL=postgresql+psycopg://provisao:change-me@postgres:5432/provisao
POSTGRES_PASSWORD=change-me
REDIS_URL=redis://redis:6379/0
FRONTEND_ORIGINS=http://localhost,http://127.0.0.1
PUBLIC_BASE_URL=http://localhost
BOOTSTRAP_ADMIN_EMAIL=admin@example.invalid
BOOTSTRAP_ADMIN_PASSWORD=
TELEGRAM_ENABLED=false
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_TOKEN_ENCRYPTION_KEY=
LOCAL_LLM_ENABLED=false
LOCAL_LLM_TEXT_MODEL=
LOCAL_LLM_VISION_MODEL=
LOCAL_STT_MODEL=
LOCAL_TTS_VOICE=
LOCAL_EMBEDDING_MODEL=
MAX_UPLOAD_BYTES=26214400
